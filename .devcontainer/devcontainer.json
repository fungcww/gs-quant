{
  "name": "GS Quant",
  "image": "mcr.microsoft.com/devcontainers/python:3.12-bookworm",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.debugpy",
        "charliermarsh.ruff"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.unittestEnabled": false
      }
    }
  },
  "mounts": [
    {
      "source": "${localWorkspaceFolder}/../research_results",
      "target": "${containerWorkspaceFolder}/research_results",
      "type": "bind"
    }
  ],
  "postCreateCommand": "pip install --upgrade pip && pip install -e '.[develop,test]'",
  "remoteUser": "vscode"
}
